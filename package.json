{
  "name": "next16-codebase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rm -rf .next node_modules",
    "docker:dev": "docker compose -f docker/dev/docker-compose.yml up --build",
    "docker:dev:down": "docker compose -f docker/dev/docker-compose.yml down",
    "docker:prod": "docker compose -f docker/prod/docker-compose.yml build --no-cache",
    "supabase:setup": "bash scripts/setup-supabase.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@serwist/turbopack": "^9.5.10",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-storybook": "^10.2.19",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "serwist": "^9.5.10",
    "shadcn": "^4.0.8",
    "storybook": "^10.3.6",
    "supabase": "^2.98.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "pnpm lint",
      "pnpm format"
    ],
    "*.{css,json,yaml,yml,mjs,md,mdx}": [
      "pnpm format"
    ]
  }
}
